# Postgres connection (matches docker-compose.yml)
DATABASE_URL=postgres://agentmq:agentmq@localhost:5432/agentmq

# Server
SERVER_PORT=4000
# Static token that the web console / admin API uses for management endpoints.
# Agent endpoints use per-agent tokens minted at registration.
ADMIN_TOKEN=dev-admin

# Reliability tunables (seconds unless noted)
DEFAULT_VISIBILITY_TIMEOUT=900
REAPER_INTERVAL_MS=5000
BACKOFF_BASE_SEC=2
BACKOFF_CAP_SEC=300
DEFAULT_MAX_RETRIES=3

# Web (Vite) — where the browser reaches the API
VITE_API_BASE=http://localhost:4000
